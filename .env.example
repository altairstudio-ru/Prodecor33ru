# Telegram Bot Configuration
# 1. Create a bot via @BotFather in Telegram
# 2. Get your chat ID via @userinfobot
# 3. Copy this file to .env and fill in the values

VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Test chat ID for debugging (add ?debug_chat=1 to URL to use this)
VITE_TELEGRAM_TEST_CHAT_ID=your_test_chat_id_here

# Channel toggles (set to 'true' or 'false')
VITE_TELEGRAM_ENABLED=true
VITE_EMAIL_ENABLED=false

# Email SMTP Configuration
# Works with Gmail, Yandex, Mail.ru, etc.
# For Gmail: use App Password (not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=info@prodecor33.ru
SMTP_TO=info@prodecor33.ru

# Optional: Test email for debugging (add ?test_email=1 to URL to use this)
VITE_EMAIL_TEST_ADDRESS=your_test_email@example.com
